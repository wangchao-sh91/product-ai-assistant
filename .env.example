APP_ENV=local

POSTGRES_DB=ai_ops_copilot
POSTGRES_USER=ai_ops
POSTGRES_PASSWORD=ai_ops_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://ai_ops:ai_ops_password@postgres:5432/ai_ops_copilot

REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=knowledge-docs

API_GATEWAY_PORT=8000
AI_ORCHESTRATOR_PORT=8001
WEB_UI_PORT=3000
AI_ORCHESTRATOR_URL=http://ai-orchestrator:8001
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

OPENAI_API_KEY=
LLM_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
